generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id        Int      @id @default(autoincrement())
  name      String
  source    String?
  sessionId String
  referrer  String?
  ua        String?
  createdAt DateTime @default(now())

  @@index([name])
  @@index([sessionId])
  @@index([createdAt])
}
